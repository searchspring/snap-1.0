{
	"name": "@athoscommerce/snap-controller",
	"version": "1.1.4",
	"description": "Snap Controllers",
	"main": "dist/cjs/index.js",
	"module": "dist/esm/index.js",
	"author": "Athos Commerce",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/AthosCommerce/snap.git"
	},
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"build": "rm -rf ./dist && rm -fr ./components/dist && tsc & p1=$!; tsc -p tsconfig.cjs.json & p2=$!; wait $p1 && wait $p2",
		"build:docs": "typedoc --out docs src/index.ts",
		"dev": "tsc --watch",
		"format": "prettier --write 'src/**/*.{js,jsx,ts,tsx}'",
		"lint": "eslint 'src/**/*.{js,jsx,ts,tsx}'",
		"test": "jest",
		"test:watch": "jest --watch"
	},
	"dependencies": {
		"@athoscommerce/snap-toolbox": "1.1.4",
		"css.escape": "1.5.1",
		"deepmerge": "4.3.1"
	},
	"devDependencies": {
		"@athoscommerce/snap-client": "1.1.4",
		"@athoscommerce/snap-event-manager": "1.1.4",
		"@athoscommerce/snap-logger": "1.1.4",
		"@athoscommerce/snap-profiler": "1.1.4",
		"@athoscommerce/snap-store-mobx": "1.1.4",
		"@athoscommerce/snap-tracker": "1.1.4",
		"@athoscommerce/snap-url-manager": "1.1.4"
	},
	"sideEffects": false,
	"files": [
		"dist/**/*"
	],
	"gitHead": "c31d6fae1461ef16d593321c312c94b85dad7d96"
}
